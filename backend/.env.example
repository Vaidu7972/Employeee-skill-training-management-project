PORT=5000
DATABASE_URL="postgresql://username:password@localhost:5432/employee_skill_management?schema=public"

JWT_ACCESS_SECRET="your_jwt_access_secret_key_minimum_32_characters"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_minimum_32_characters"

JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Login security parameters
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15
REMEMBER_ME_EXPIRATION_DAYS=30

LOG_LEVEL="info"
